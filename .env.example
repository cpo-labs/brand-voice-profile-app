# Copy to .env.local and fill in.

# ─── Required ────────────────────────────────────────────────────────────

# Anthropic API Key (Server-side LLM)
ANTHROPIC_API_KEY=""

# Turso (libsql). Local: file:./data/dev.db. Production: libsql://<db>.turso.io
DATABASE_URL="file:./data/dev.db"
DATABASE_AUTH_TOKEN=""

# Public URL used for permalinks in emails. In production: https://voice.labs.appsales-consulting.de
PUBLIC_BASE_URL="http://localhost:3000"

# Resend (for permalink emails; optional in dev — will fall back to console log)
RESEND_API_KEY=""
RESEND_FROM="Brand Voice Profile <hello@labs.appsales-consulting.de>"

# Contact email surfaced as the lead CTA on the result page
CONTACT_EMAIL="hello@appsales-consulting.de"

# ─── Rate Limits ─────────────────────────────────────────────────────────
PROFILE_LIMIT_PER_EMAIL="1"
PROFILE_LIMIT_GLOBAL_MONTHLY="100"

# ─── Forward Inbox (IMAP poller → /api/inbound) ──────────────────────────
# Shared secret the Mac-Mini poller signs every inbound request with
# (header: x-poller-secret). Must match the poller's POLLER_SHARED_SECRET.
# Leave empty to disable the inbound endpoint (it fails closed → 401).
POLLER_SHARED_SECRET=""
