# Copy to .env.local and fill in.

# ─── Required ────────────────────────────────────────────────────────────

# Anthropic API Key (Server-side LLM)
ANTHROPIC_API_KEY=""

# Turso (libsql). Local: file:./data/dev.db. Production: libsql://<db>.turso.io
DATABASE_URL="file:./data/dev.db"
DATABASE_AUTH_TOKEN=""

# better-auth Session-Secret. Generate via:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Resend (for Magic-Link Emails)
RESEND_API_KEY=""
RESEND_FROM="Brand Voice Profile <hello@labs.appsales-consulting.de>"

# ─── Rate Limits ─────────────────────────────────────────────────────────
PROFILE_LIMIT_PER_EMAIL="1"
PROFILE_LIMIT_GLOBAL_MONTHLY="100"
