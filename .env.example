# Brand Voice Profile — Environment-Vorlage
# Kopiere diese Datei nach .env.local und trage echte Werte ein.
# .env.local wird NIE committet. Vor Public-Deploy muessen die mit
# [VERCEL] markierten Variablen auch im Vercel-Projekt gesetzt sein.

# ─── Anthropic (Server-side LLM) ─────────────────────────────────────────
# [VERCEL]
ANTHROPIC_API_KEY=""

# ─── Turso / libSQL (DB) ─────────────────────────────────────────────────
# Werte holen:
#   turso db show <db-name> --url
#   turso db tokens create <db-name>
# Lokal alternativ SQLite: DATABASE_URL="file:./data/dev.db"
# [VERCEL]
DATABASE_URL=""
DATABASE_AUTH_TOKEN=""

# ─── Public URL ──────────────────────────────────────────────────────────
# In Prod die oeffentliche Basis-URL (z.B. https://labs.appsales-consulting.de)
# [VERCEL]
PUBLIC_BASE_URL="http://localhost:3000"

# ─── Resend (Profil-Mail mit VOICE.md-Anhang, optional in dev) ───────────
# Wird nur genutzt, wenn der Nutzer im Upload optional eine E-Mail angibt.
# [VERCEL]
RESEND_API_KEY=""
RESEND_FROM="Brand Voice Profile <hello@labs.appsales-consulting.de>"

# ─── Contact & Limits ────────────────────────────────────────────────────
CONTACT_EMAIL="hello@appsales-consulting.de"
PROFILE_LIMIT_PER_EMAIL="1"
PROFILE_LIMIT_GLOBAL_MONTHLY="100"

# ─── E-Mail-Hash (PII-Schutz) ────────────────────────────────────────────
# Server-Secret fuer den HMAC-SHA256 ueber E-Mail-Adressen. In der DB steht
# dauerhaft NUR dieser Hash, nie der Klartext. Rate-Limit/Dedup laeuft ueber
# den Hash. MUSS vor Public-Deploy in Vercel gesetzt sein — sonst werfen die
# Lookups (EMAIL_HASH_SECRET is not set). Generieren z.B. mit:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Achtung: Aendern entwertet alle bestehenden Hashes.
# [VERCEL]
EMAIL_HASH_SECRET=""
